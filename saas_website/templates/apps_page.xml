<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="apps_page" name="SaaS Apps Marketplace">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <div class="container py-5 saas-apps-page">

                    <!-- Header -->
                    <div class="text-center mb-5">
                        <h1 class="display-4 fw-bold">Apps</h1>
                        <p class="lead text-muted">
                            Browse available modules for your SaaS instance.
                        </p>
                    </div>

                    <!-- Search + Version Filter Bar -->
                    <div class="row justify-content-center mb-4 g-3">

                        <!-- Search -->
                        <div class="col-md-6">
                            <form action="/apps" method="get" class="input-group">
                                <t t-if="current_version">
                                    <input type="hidden" name="version"
                                           t-att-value="current_version.id"/>
                                </t>
                                <input type="text" class="form-control"
                                       name="search" placeholder="Search modules..."
                                       t-att-value="search"/>
                                <button class="btn btn-primary" type="submit">
                                    <i class="fa fa-search"/>
                                </button>
                            </form>
                        </div>

                        <!-- Version Filter -->
                        <div class="col-md-6 text-md-end text-center">
                            <div class="btn-group flex-wrap" role="group">
                                <a t-attf-href="/apps?search=#{search}"
                                   t-attf-class="btn btn-sm #{'btn-primary' if not current_version else 'btn-outline-primary'}">
                                    All Versions
                                </a>
                                <t t-foreach="versions" t-as="ver">
                                    <a t-attf-href="/apps?version=#{ver.id}&amp;search=#{search}"
                                       t-attf-class="btn btn-sm #{'btn-primary' if current_version and current_version.id == ver.id else 'btn-outline-primary'}">
                                        <t t-esc="ver.name"/>
                                    </a>
                                </t>
                            </div>
                        </div>
                    </div>

                    <!-- Result Count -->
                    <div class="mb-4 text-muted">
                        <t t-esc="module_count"/> module(s) found
                        <t t-if="search">
                            for "<strong><t t-esc="search"/></strong>"
                        </t>
                    </div>

                    <!-- Grouped Module Grid -->
                    <t t-foreach="grouped_modules" t-as="group">

                        <!-- Version Section Header (only when viewing all) -->
                        <t t-if="not current_version">
                            <div class="d-flex align-items-center mb-3 mt-4">
                                <h4 class="mb-0 fw-bold">
                                    Odoo <t t-esc="group['version'].name"/>
                                </h4>
                                <span class="badge text-bg-secondary ms-2">
                                    <t t-esc="len(group['modules'])"/>
                                </span>
                            </div>
                            <hr class="mt-0 mb-3"/>
                        </t>

                        <div class="row g-4 mb-5">
                            <t t-foreach="group['modules']" t-as="module">
                                <div class="col-xl-3 col-lg-4 col-md-6">
                                    <div class="card h-100 shadow-sm saas-app-card">

                                        <!-- Module Image -->
                                        <div class="saas-app-img-wrapper text-center">
                                            <t t-if="module.image_1920">
                                                <img t-attf-src="/web/image/product.template/#{module.id}/image_1920/128x128"
                                                     class="saas-app-icon"
                                                     t-att-alt="module.name"
                                                     loading="lazy"/>
                                            </t>
                                            <t t-else="">
                                                <div class="saas-app-icon-placeholder">
                                                    <i class="fa fa-puzzle-piece fa-3x text-muted"/>
                                                </div>
                                            </t>
                                        </div>

                                        <div class="card-body d-flex flex-column pt-2">
                                            <!-- Module Name -->
                                            <h6 class="card-title fw-bold mb-1 text-truncate"
                                                t-att-title="module.name">
                                                <t t-esc="module.name"/>
                                            </h6>

                                            <!-- Technical Name -->
                                            <small class="text-muted d-block mb-2">
                                                <t t-esc="module.technical_name"/>
                                            </small>

                                            <!-- Description -->
                                            <p class="card-text text-muted small mb-2 saas-app-desc"
                                               t-if="module.description_sale">
                                                <t t-esc="module.description_sale"/>
                                            </p>

                                            <!-- Footer: Author + Price -->
                                            <div class="mt-auto pt-2 border-top">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <small class="text-muted text-truncate me-2"
                                                           t-if="module.saas_author"
                                                           t-att-title="module.saas_author">
                                                        <i class="fa fa-user me-1"/>
                                                        <t t-esc="module.saas_author"/>
                                                    </small>
                                                    <span class="fw-bold text-nowrap">
                                                        <t t-if="module.list_price > 0">
                                                            $<t t-esc="'%.2f' % module.list_price"/>
                                                        </t>
                                                        <t t-else="">
                                                            <span class="text-success">Free</span>
                                                        </t>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>

                    <!-- Empty State -->
                    <t t-if="not grouped_modules">
                        <div class="text-center py-5">
                            <i class="fa fa-puzzle-piece fa-4x text-muted d-block mb-3"/>
                            <h4 class="text-muted">No modules found</h4>
                            <t t-if="search">
                                <p class="text-muted">
                                    Try a different search term or
                                    <a href="/apps">view all modules</a>.
                                </p>
                            </t>
                        </div>
                    </t>

                </div>
            </div>
        </t>
    </template>

</odoo>
