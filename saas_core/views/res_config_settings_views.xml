<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit base settings form to add SaaS settings -->
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.saas_core</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="50"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="SaaS Manager" string="SaaS Manager" name="saas_core">

                    <block title="Instance Defaults" name="saas_instance_defaults_container">
                        <setting id="saas_default_instance_starting_port_setting"
                                 string="Default Starting Port"
                                 help="First port number used when auto-assigning HTTP / longpolling ports to new instances.">
                            <field name="saas_default_instance_starting_port"/>
                        </setting>
                    </block>

                    <block title="Backup Storage" name="saas_backup_storage_container">
                        <setting id="saas_backup_provider_setting"
                                 string="Cloud Provider"
                                 help="Select the cloud storage provider for automatic backups.">
                            <field name="saas_backup_provider"/>
                        </setting>
                        <setting id="saas_backup_bucket_name_setting"
                                 string="Bucket Name"
                                 help="Name of the cloud storage bucket.">
                            <field name="saas_backup_bucket_name"/>
                        </setting>
                        <setting id="saas_backup_region_setting"
                                 string="Region"
                                 help="Cloud region (e.g. us-east-1, europe-west1, nyc3)."
                                 invisible="saas_backup_provider == 'gcs'">
                            <field name="saas_backup_region"/>
                        </setting>
                        <setting id="saas_backup_access_key_setting"
                                 string="Access Key"
                                 help="Access key ID for authentication."
                                 invisible="saas_backup_provider == 'gcs'">
                            <field name="saas_backup_access_key"/>
                        </setting>
                        <setting id="saas_backup_secret_key_setting"
                                 string="Secret Key"
                                 help="Secret access key for authentication."
                                 invisible="saas_backup_provider == 'gcs'">
                            <field name="saas_backup_secret_key" password="True"/>
                        </setting>
                        <setting id="saas_backup_service_account_key_setting"
                                 string="Service Account JSON Key"
                                 help="Upload the GCP service account key JSON file."
                                 invisible="saas_backup_provider != 'gcs'">
                            <field name="saas_backup_service_account_key_file"
                                   filename="saas_backup_service_account_key_filename"/>
                            <field name="saas_backup_service_account_key_filename"
                                   invisible="1"/>
                        </setting>
                        <setting id="saas_backup_endpoint_setting"
                                 string="Endpoint URL"
                                 help="Custom S3-compatible endpoint. Required for DigitalOcean Spaces."
                                 invisible="saas_backup_provider == 'gcs'">
                            <field name="saas_backup_endpoint"
                                   placeholder="https://nyc3.digitaloceanspaces.com"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <!-- Action to open settings with saas_core module context -->
    <record id="action_saas_master_config_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'saas_core', 'bin_size': False}</field>
    </record>

</odoo>
